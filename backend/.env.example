PORT=3000
NODE_ENV=development

# Comma-separated frontend origins allowed by CORS
FRONTEND_ORIGIN=http://127.0.0.1:5173,http://localhost:5173

# Required for real database persistence
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Optional for real email delivery (if missing, backend logs as mocked)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# Optional for real SMS delivery (if missing, backend logs as mocked)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
